---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  robots?: string;
}

const {
  title = "Attendance Calculator — Track & Optimize Your Class Attendance | Attendo",
  description = "Free online attendance calculator for students. Calculate 75% attendance, track classes, find how many classes you can bunk, and optimize your attendance percentage.",
  ogImage = "/favicon-96x96.png",
  robots
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Favicon Links -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />


    <meta name="generator" content={Astro.generator} />
    {robots && <meta name="robots" content={robots} />}

    <link rel="canonical" href={`https://attendooo.com${Astro.url.pathname}`} />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Attendo" />
    <meta name="keywords" content="attendance calculator, attendance tracker, class attendance calculator, attendance percentage calculator, student attendance tool" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://attendooo.com${Astro.url.pathname}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Attendo" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={`https://attendooo.com${Astro.url.pathname}`} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Google Fonts: Inter and JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />

    <!-- Blocking Theme Script to Prevent Flash (defaults to dark) -->
    <script is:inline>
      (function() {
        const getTheme = () => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          return 'dark';
        };

        const theme = getTheme();
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
        localStorage.setItem('theme', theme);
      })();
    </script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-93TSMGE874"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-93TSMGE874');
    </script>
  </head>
  <body class="bg-canvas-soft dark:bg-[#0a0a0a] text-ink dark:text-[#d4d4d4] font-sans antialiased selection:bg-primary dark:selection:bg-white dark:selection:text-primary min-h-screen flex flex-col transition-colors duration-150">
    <!-- Accessibility Skip Link -->
    <a href="#main-content" data-i18n="skipToContent" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary dark:focus:bg-white focus:text-on-primary dark:focus:text-primary focus:rounded-sm focus:shadow-level3 focus:outline-none">
      Skip to content
    </a>
    <slot />
  </body>
</html>
