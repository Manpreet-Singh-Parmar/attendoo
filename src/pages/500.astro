---
const title = "500 — Server Error | Attendo";
const description = "An unexpected error occurred on our end.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
  </head>
  <body style="margin:0; background:#000; color:#fff; display:flex; align-items:center; justify-content:center; min-height:100vh; font-family:system-ui,-apple-system,sans-serif;">
    <main style="text-align:center; padding:2rem;">
      <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.15em; color:#666; margin:0 0 0.5rem;">Error 500</p>
      <h1 style="font-size:3rem; font-weight:700; margin:0 0 0.75rem; letter-spacing:-0.03em;">Something went wrong</h1>
      <p style="color:#999; max-width:24rem; margin:0 auto 1.5rem; line-height:1.5;">An unexpected error occurred on our end. Please try refreshing the page or come back later.</p>
      <a href="/" style="display:inline-block; background:#fff; color:#000; text-decoration:none; font-size:0.875rem; font-weight:500; padding:0.625rem 1.25rem; border-radius:999px;">Back to Home</a>
    </main>
  </body>
</html>
