---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us — Attendo">
  <header class="sticky top-0 z-40 w-full border-b border-hairline dark:border-[#222] bg-canvas/80 dark:bg-black/80 backdrop-blur-md transition-colors duration-150">
    <div class="max-w-5xl mx-auto px-4 md:px-6 w-full flex items-center justify-between h-14">
      <a href="/" class="flex items-center gap-2 font-sans font-semibold tracking-tight text-ink dark:text-white text-base focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none rounded-sm px-1 py-0.5">
        <img src="/favicon.svg" class="w-5 h-5" alt="Attendo" />
        <div class="flex flex-col">
          <span>Attendo</span>
          <span class="text-xs text-body/50 dark:text-gray-500/50 font-normal leading-none">attendance calculator</span>
        </div>
      </a>
      <nav class="hidden md:flex items-center gap-1">
        <a href="/calculator" class="text-xs font-sans text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] px-2.5 py-1.5 rounded-full transition-all focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none">Calculator</a>
        <a href="/subjects" class="text-xs font-sans text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] px-2.5 py-1.5 rounded-full transition-all focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none">Courses</a>
        <a href="/simulator" class="text-xs font-sans text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] px-2.5 py-1.5 rounded-full transition-all focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none">Simulator</a>
        <a href="/analytics" class="text-xs font-sans text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] px-2.5 py-1.5 rounded-full transition-all focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none">Analytics</a>
        <span class="w-px h-4 bg-hairline dark:bg-[#333] mx-1"></span>
        <a href="/about" class="text-xs font-sans text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] px-2.5 py-1.5 rounded-full transition-all focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none">About</a>
        <a href="/contact" class="text-xs font-sans bg-canvas-soft-2 dark:bg-[#1a1a1a] text-ink dark:text-white px-2.5 py-1.5 rounded-full transition-all focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none">Contact</a>
        <a href="/privacy" class="text-xs font-sans text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] px-2.5 py-1.5 rounded-full transition-all focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none">Privacy</a>
        <a href="/terms" class="text-xs font-sans text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] px-2.5 py-1.5 rounded-full transition-all focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none">Terms</a>
      </nav>
      <div class="flex items-center gap-2 sm:gap-3">
        <div class="lang-dropdown relative">
          <button id="lang-trigger" class="w-8 h-8 rounded-sm bg-canvas dark:bg-[#111] border border-hairline dark:border-[#222] hover:bg-canvas-soft-2 dark:hover:bg-[#1a1a1a] text-ink dark:text-white flex items-center justify-center cursor-pointer transition-all focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none" aria-label="Switch language">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802" />
            </svg>
          </button>
          <div id="lang-menu" class="lang-dropdown-menu hidden"></div>
        </div>
        <button id="theme-toggler" class="relative w-8 h-8 rounded-sm bg-canvas dark:bg-[#111] border border-hairline dark:border-[#222] hover:bg-canvas-soft-2 dark:hover:bg-[#1a1a1a] text-ink dark:text-white flex items-center justify-center cursor-pointer transition-all focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none" aria-label="Toggle theme">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 block dark:hidden fill-none stroke-current stroke-2" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M16.24 16.24l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" /></svg>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden dark:block fill-none stroke-current stroke-2" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" /></svg>
        </button>
        <button id="mobile-menu-trigger" class="relative w-8 h-8 rounded-sm bg-canvas dark:bg-[#111] border border-hairline dark:border-[#222] hover:bg-canvas-soft-2 dark:hover:bg-[#1a1a1a] text-ink dark:text-white flex md:hidden items-center justify-center cursor-pointer transition-all focus-visible:ring-2 focus-visible:ring-white focus-visible:outline-none" aria-label="Toggle mobile menu" aria-expanded="false" aria-controls="mobile-menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-none stroke-current stroke-2" viewBox="0 0 24 24" aria-hidden="true">
            <path class="line-top transition-all duration-200 origin-center" d="M4 6h16" />
            <path class="line-mid transition-all duration-200" d="M4 12h16" />
            <path class="line-bot transition-all duration-200 origin-center" d="M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="hidden border-t border-hairline dark:border-[#222] bg-canvas dark:bg-black w-full overflow-hidden transition-all duration-200 ease-in-out md:hidden">
      <div class="px-4 py-4 flex flex-col gap-2">
        <a href="/calculator" class="mobile-nav-link text-xs font-sans text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] px-4 py-2.5 rounded transition-all">Calculator</a>
        <a href="/subjects" class="mobile-nav-link text-xs font-sans text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] px-4 py-2.5 rounded transition-all">Courses</a>
        <a href="/simulator" class="mobile-nav-link text-xs font-sans text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] px-4 py-2.5 rounded transition-all">Simulator</a>
        <a href="/analytics" class="mobile-nav-link text-xs font-sans text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] px-4 py-2.5 rounded transition-all">Analytics</a>
        <div class="h-px bg-hairline dark:bg-[#222] my-1"></div>
        <a href="/about" class="mobile-nav-link text-xs font-sans text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] px-4 py-2.5 rounded transition-all">About</a>
        <a href="/contact" class="mobile-nav-link text-xs font-sans text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] px-4 py-2.5 rounded transition-all">Contact</a>
        <a href="/privacy" class="mobile-nav-link text-xs font-sans text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] px-4 py-2.5 rounded transition-all">Privacy</a>
        <a href="/terms" class="mobile-nav-link text-xs font-sans text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] px-4 py-2.5 rounded transition-all">Terms</a>
      </div>
    </div>
  </header>

  <main id="main-content" class="flex-grow w-full focus:outline-none">
    <div class="max-w-3xl mx-auto px-4 md:px-6 py-16 md:py-20">
      <span class="inline-block font-mono text-[11px] text-mute dark:text-gray-500 uppercase tracking-widest mb-4">Contact</span>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight text-ink dark:text-white mb-8">Contact Us</h1>

      <div class="prose prose-sm max-w-none text-body dark:text-gray-400 space-y-6 leading-relaxed">
        <p>Have a question, suggestion, or feedback? We would love to hear from you. Here is how you can reach us:</p>

        <div class="bg-canvas dark:bg-[#111] border border-hairline dark:border-[#222] rounded-md p-6 space-y-6 not-prose">
          <div class="flex items-start gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-ink dark:text-white shrink-0 mt-0.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            <div>
              <h3 class="text-sm font-semibold text-ink dark:text-white mb-1">Email</h3>
              <a href="mailto:hello@Attendo.com" class="text-xs text-link dark:text-blue-400 hover:underline">hello@Attendo.com</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-ink dark:text-white shrink-0 mt-0.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
            <div>
              <h3 class="text-sm font-semibold text-ink dark:text-white mb-1">Report an Issue</h3>
              <p class="text-xs text-body dark:text-gray-400">If you found a bug or have a feature request, please open an issue on our <a href="https://github.com/anomalyco/Attendo/issues" target="_blank" rel="noopener noreferrer" class="text-link dark:text-blue-400 hover:underline">GitHub repository</a>.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-ink dark:text-white shrink-0 mt-0.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
            </svg>
            <div>
              <h3 class="text-sm font-semibold text-ink dark:text-white mb-1">Response Time</h3>
              <p class="text-xs text-body dark:text-gray-400">We typically respond within 24-48 hours during business days.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <footer class="border-t border-hairline dark:border-[#222] bg-canvas dark:bg-[#0a0a0a] py-12">
    <div class="max-w-5xl mx-auto px-4 md:px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="col-span-2 md:col-span-1">
          <a href="/" class="flex items-center gap-2 font-sans font-semibold tracking-tight text-ink dark:text-white text-base mb-3">
            <img src="/favicon.svg" class="w-5 h-5" alt="Attendo" />
            <span>Attendo</span>
          </a>
          <p class="text-xs text-body dark:text-gray-400 leading-relaxed">Free online attendance calculator and tracker for students. Calculate 75% attendance, track multiple subjects, and optimize your class attendance.</p>
        </div>
        <div>
          <h4 class="text-[10px] font-mono text-mute dark:text-gray-500 uppercase tracking-wider mb-3">Tools</h4>
          <ul class="space-y-2">
            <li><a href="/calculator" class="text-xs text-body dark:text-gray-400 hover:text-ink dark:hover:text-white transition-colors">Calculator</a></li>
            <li><a href="/subjects" class="text-xs text-body dark:text-gray-400 hover:text-ink dark:hover:text-white transition-colors">Courses</a></li>
            <li><a href="/simulator" class="text-xs text-body dark:text-gray-400 hover:text-ink dark:hover:text-white transition-colors">Simulator</a></li>
            <li><a href="/analytics" class="text-xs text-body dark:text-gray-400 hover:text-ink dark:hover:text-white transition-colors">Analytics</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-[10px] font-mono text-mute dark:text-gray-500 uppercase tracking-wider mb-3">Quick Links</h4>
          <ul class="space-y-2">
            <li><a href="/settings" class="text-xs text-body dark:text-gray-400 hover:text-ink dark:hover:text-white transition-colors">Settings</a></li>
            <li><a href="/calculator" class="text-xs text-body dark:text-gray-400 hover:text-ink dark:hover:text-white transition-colors">75% Calculator</a></li>
            <li><a href="/simulator" class="text-xs text-body dark:text-gray-400 hover:text-ink dark:hover:text-white transition-colors">Bunk Calculator</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-[10px] font-mono text-mute dark:text-gray-500 uppercase tracking-wider mb-3">Company</h4>
          <ul class="space-y-2">
            <li><a href="/about" class="text-xs text-body dark:text-gray-400 hover:text-ink dark:hover:text-white transition-colors">About Us</a></li>
            <li><a href="/contact" class="text-xs text-body dark:text-gray-400 hover:text-ink dark:hover:text-white transition-colors">Contact Us</a></li>
            <li><a href="/privacy" class="text-xs text-body dark:text-gray-400 hover:text-ink dark:hover:text-white transition-colors">Privacy Policy</a></li>
            <li><a href="/terms" class="text-xs text-body dark:text-gray-400 hover:text-ink dark:hover:text-white transition-colors">Terms &amp; Conditions</a></li>
          </ul>
        </div>
      </div>
      <div class="mt-10 pt-6 border-t border-hairline dark:border-[#222] flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-[10px] text-mute dark:text-gray-500">&copy; 2026 Attendo. All rights reserved.</p>
        <p class="text-[10px] text-mute dark:text-gray-500">Free Attendance Calculator for Students</p>
      </div>
    </div>
  </footer>

  <div id="aria-announcer" class="sr-only" aria-live="polite"></div>
</Layout>

<script>
  import { applyTranslations, setLanguage, getCurrentLang, supportedLanguages } from '../lib/i18n';

  const themeToggler = document.getElementById('theme-toggler');
  const mobileMenuTrigger = document.getElementById('mobile-menu-trigger');
  const mobileMenu = document.getElementById('mobile-menu');
  const langTrigger = document.getElementById('lang-trigger');
  const langMenu = document.getElementById('lang-menu');
  const ariaAnnouncer = document.getElementById('aria-announcer');

  function announce(msg: string) {
    if (ariaAnnouncer) ariaAnnouncer.textContent = msg;
  }

  themeToggler?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.contains('dark');
    document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'light' : 'dark');
  });

  mobileMenuTrigger?.addEventListener('click', () => {
    const isHidden = mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden');
    mobileMenuTrigger.setAttribute('aria-expanded', (!isHidden).toString());
  });
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      mobileMenuTrigger.setAttribute('aria-expanded', 'false');
    });
  });

  langTrigger?.addEventListener('click', () => {
    langMenu.classList.toggle('hidden');
  });
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.lang-dropdown')) {
      langMenu?.classList.add('hidden');
    }
  });

  function populateLanguageMenus() {
    const currentLang = getCurrentLang();
    if (langMenu) {
      langMenu.innerHTML = supportedLanguages.map(l =>
        `<button data-lang="${l.code}" class="${l.code === currentLang ? 'active ' : ''}">${l.name}</button>`
      ).join('');
      langMenu.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', () => {
          const lang = btn.getAttribute('data-lang');
          if (lang) setLanguage(lang);
        });
      });
    }
  }
  populateLanguageMenus();
  applyTranslations();
</script>
