<script>
  import { applyTranslations, setLanguage, getCurrentLang, t, tt, supportedLanguages } from '../lib/i18n';

  const themeToggler = document.getElementById('theme-toggler');
  const mobileMenuTrigger = document.getElementById('mobile-menu-trigger');
  const mobileMenu = document.getElementById('mobile-menu');
  const langTrigger = document.getElementById('lang-trigger');
  const langMenu = document.getElementById('lang-menu');
  const ariaAnnouncer = document.getElementById('aria-announcer');

  function announce(msg: string) {
    if (ariaAnnouncer) ariaAnnouncer.textContent = msg;
  }

  // Theme toggle
  themeToggler?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      document.documentElement.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      document.documentElement.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
  });

  // Mobile menu
  mobileMenuTrigger?.addEventListener('click', () => {
    const isHidden = mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden');
    mobileMenuTrigger.setAttribute('aria-expanded', (!isHidden).toString());
  });
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      mobileMenuTrigger.setAttribute('aria-expanded', 'false');
    });
  });

  // FAQ Accordion
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', (!expanded).toString());
      const answer = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector('.faq-icon') as HTMLElement;
      if (expanded) {
        answer.classList.add('hidden');
        icon.style.transform = 'rotate(0deg)';
      } else {
        answer.classList.remove('hidden');
        icon.style.transform = 'rotate(180deg)';
      }
    });
  });

  // Language switcher desktop
  langTrigger?.addEventListener('click', () => {
    langMenu.classList.toggle('hidden');
  });
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.lang-dropdown')) {
      langMenu?.classList.add('hidden');
    }
  });

  // Populate language menus dynamically
  function populateLanguageMenus() {
    const currentLang = getCurrentLang();
    const containers = [
      { el: document.getElementById('lang-menu'), cls: '' },
      { el: document.getElementById('lang-mobile-container'), cls: 'text-xs px-3 py-1.5 rounded border border-hairline dark:border-[#333] text-body dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-canvas-soft-2 dark:hover:bg-[#111] cursor-pointer' },
    ];
    containers.forEach(({ el, cls }) => {
      if (!el) return;
      el.innerHTML = supportedLanguages.map(l =>
        `<button data-lang="${l.code}" class="${l.code === currentLang ? 'active ' : ''}${cls}">${l.name}</button>`
      ).join('');
      el.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', () => {
          const lang = btn.getAttribute('data-lang');
          if (lang) setLanguage(lang);
        });
      });
    });
  }
  populateLanguageMenus();

  // One-liner calculator
  const quickInput = document.getElementById('quick-one-liner-input') as HTMLInputElement;
  const resultContainer = document.getElementById('quick-one-liner-result-container') as HTMLDivElement;
  const resultText = document.getElementById('quick-one-liner-result') as HTMLParagraphElement;

  quickInput?.addEventListener('input', () => {
    const raw = quickInput.value.trim();
    if (!raw) {
      resultContainer.classList.add('hidden');
      return;
    }
    const match = raw.match(/(\d+)\s*(?:\/|out\s+of|of)\s*(\d+)/i);
    if (!match) {
      resultContainer.classList.remove('hidden');
      resultContainer.className = 'animate-slide-in p-3.5 rounded border border-hairline dark:border-[#222] bg-canvas-soft dark:bg-[#141414]';
      resultText.innerHTML = t('calculator.invalidFormat');
      return;
    }
    const present = parseInt(match[1], 10);
    const total = parseInt(match[2], 10);
    if (total === 0 || present > total) {
      resultContainer.classList.remove('hidden');
      resultContainer.className = 'animate-slide-in p-3.5 rounded border border-hairline dark:border-[#222] bg-canvas-soft dark:bg-[#141414]';
      resultText.innerHTML = present > total ? t('calculator.attendedExceeds') : t('calculator.totalZero');
      return;
    }
    const pct = total > 0 ? (present / total) * 100 : 0;
    const target = 75;
    const needed = pct < target ? Math.ceil((target/100 * total - present) / (1 - target/100)) : Math.floor((present - target/100 * total) / (target/100));
    const status = pct >= target ? 'safe' : 'risk';
    const statusColor = status === 'safe' ? 'text-success border-blue-500/20 bg-blue-500/5 dark:bg-blue-500/10' : 'text-warning border-warning/20 bg-warning/5 dark:bg-warning/10';
    const msg = status === 'safe'
      ? (needed > 0 ? tt('calculator.bunkMsg', { n: needed, es: needed > 1 ? 'es' : '' }) : t('calculator.limitMsg'))
      : tt('calculator.attendMsg', { n: needed, es: needed > 1 ? 'es' : '' });

    resultContainer.classList.remove('hidden');
    resultContainer.className = `animate-slide-in p-3.5 rounded border ${statusColor}`;
    resultText.innerHTML = `<strong class="text-ink dark:text-white">${pct.toFixed(1)}%</strong> &mdash; ${msg} <span class="block text-[10px] text-mute dark:text-gray-500 mt-0.5">${present}/${total} ${t('calculator.classes')}</span>`;
  });

  // Apply i18n
  applyTranslations();
</script>
